@model PaymentApp.DTOs.CreatePaymentDto

@{
    ViewData["Title"] = "Создание платежа";
}

<div class="row justify-content-center">
    <div class="col-lg-9">
        <h1 class="page-title">Создание платежа</h1>
        <p class="page-subtitle">Заполните форму для создания новой платежной операции.</p>

        <div class="card-clean">
            <form asp-action="Create" method="post">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="WalletNumber" class="form-label">Номер кошелька</label>
                        <input asp-for="WalletNumber" class="form-control" placeholder="Например: WALLET123" />
                        <span asp-validation-for="WalletNumber" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Account" class="form-label">Аккаунт / UserId</label>
                        <input asp-for="Account" class="form-control" placeholder="Например: user001" />
                        <span asp-validation-for="Account" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Email" class="form-label">Email</label>
                        <input asp-for="Email" class="form-control" placeholder="example@mail.com" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Phone" class="form-label">Телефон</label>
                        <input asp-for="Phone" class="form-control" placeholder="+77001234567" />
                        <span asp-validation-for="Phone" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Amount" class="form-label">Сумма</label>
                        <input asp-for="Amount" class="form-control" placeholder="1500" />
                        <span asp-validation-for="Amount" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Currency" class="form-label">Валюта</label>
                        <select asp-for="Currency" class="form-select">
                            <option value="">Выберите валюту</option>
                            <option value="USD">USD</option>
                            <option value="RUB">RUB</option>
                            <option value="EUR">EUR</option>
                        </select>
                        <span asp-validation-for="Currency" class="text-danger"></span>
                    </div>

                    <div class="col-12 mb-4">
                        <label asp-for="Comment" class="form-label">Комментарий</label>
                        <textarea asp-for="Comment" class="form-control" placeholder="Дополнительная информация о платеже"></textarea>
                    </div>
                </div>

                <button type="submit" class="btn btn-app-primary">Создать платеж</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}